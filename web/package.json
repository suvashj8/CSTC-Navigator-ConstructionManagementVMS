{
  "name": "navigator-vms-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "start": "next start -p 3000",
    "worker": "node scripts/worker.mjs",
    "seed": "tsx --env-file=.env.development scripts/seed-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@types/swagger-ui-react": "^5.18.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "navigator-vms": "file:..",
    "next": "^15.1.3",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.19.0",
    "pg": "^8.13.1",
    "pino": "^9.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swagger-ui-react": "^5.32.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
