# VMS dev DB — Docker Postgres on host port 7002 (7000-series stack)
MAIN_DB_HOST=localhost
MAIN_DB_PORT=7002
MAIN_DB_USER=vms
MAIN_DB_PASSWORD=vms
MAIN_DB_NAME=vms_main
# Redis optional for login — leave unset to skip health noise; set when you need queues
# REDIS_ADDR=127.0.0.1:6379
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
# dev:next / docker:reseed run npm run seed — avoid double full seed on API boot (demo login auto-heals if seed was skipped)
SEED_ON_STARTUP=false
EXPORT_DIR=./exports
CORS_ORIGINS=http://localhost:7000,http://127.0.0.1:7000,http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,http://localhost
VMS_ALLOW_LAN_CORS=true
