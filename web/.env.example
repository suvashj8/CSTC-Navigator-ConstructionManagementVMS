# Main database (platform registry)
MAIN_DB_HOST=localhost
# Docker dev uses host port 15432 (see docker-compose.yml) — avoids Windows Postgres on 5432+
MAIN_DB_PORT=15432
MAIN_DB_USER=vms
MAIN_DB_PASSWORD=vms
MAIN_DB_NAME=vms_main

# Auth
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRY_HOURS=8

# Optional Redis (health check; future queue)
REDIS_ADDR=localhost:6379
# Set to "true" to require Redis for health check / readiness
VMS_REDIS_REQUIRED=false

# Reports export directory
# PRODUCTION: Set to a persistent volume mount path (e.g., /data/exports)
# or use object storage (S3) by implementing custom storage adapter
EXPORT_DIR=./exports

# Run migrations + demo seed on server start
SEED_ON_STARTUP=true

# CORS (comma-separated origins)
# PRODUCTION: Set to your frontend domain(s) only, e.g., https://app.example.com
# DEV: http://localhost:5173,capacitor://localhost,http://localhost
CORS_ORIGINS=http://localhost:5173,capacitor://localhost,http://localhost

# Enable LAN CORS in development (for mobile testing on local network)
VMS_ALLOW_LAN_CORS=true

# Logging
LOG_LEVEL=info

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
