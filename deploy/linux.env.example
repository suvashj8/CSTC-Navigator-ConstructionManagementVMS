# Copy to deploy/linux.env and edit before first deploy on your Linux server.
#   cp deploy/linux.env.example deploy/linux.env

# Client-facing ports (7000 series — must not conflict with other projects)
VMS_UI_PORT=7000
VMS_API_PORT=7001

# Database (internal Docker network only — not exposed on host)
POSTGRES_USER=vms
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=vms_main

# Auth — use a long random string in production
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# true on first run (creates demo tenant); set false after provisioning
SEED_ON_STARTUP=true

# Allowed browser origins (comma-separated, no spaces).
# Include every URL clients use: LAN IP, domain, with correct port.
# Example server IP 192.168.1.50 and domain navigator.cstc.local:
CORS_ORIGINS=http://192.168.1.50:7000,http://navigator.cstc.local:7000,http://192.168.1.50:7001,http://navigator.cstc.local:7001
