# Navigator VMS - Production Environment Variables
# Copy to .env and fill in values
# Never commit .env to version control!

# =============================================================================
# Database (local PostgreSQL on the host — not in Docker)
# =============================================================================
MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_USER=vms
MAIN_DB_PASSWORD=vms
MAIN_DB_NAME=vms_main

# Legacy names still read by some tooling
POSTGRES_USER=vms
POSTGRES_PASSWORD=vms
POSTGRES_DB=vms_main

# =============================================================================
# Redis
# =============================================================================
REDIS_PASSWORD=changeme_redis_password_here

# =============================================================================
# Authentication
# =============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme_min_32_chars_base64_encoded
JWT_EXPIRY_HOURS=8
REFRESH_TOKEN_EXPIRY_DAYS=30

# =============================================================================
# Docker host ports (7000 series)
# =============================================================================
# UI: 7000 | API: 7001 | Redis: 7003 | Postgres: localhost:5432 (host, not Docker)
VMS_UI_PORT=7000
VMS_API_PORT=7001

# =============================================================================
# CORS - Set to your frontend domain(s) in production
# =============================================================================
# Example: http://localhost:7000,https://app.example.com
CORS_ORIGINS=http://localhost:7000

# =============================================================================
# API & Frontend
# =============================================================================
# Frontend API URL (relative path works when frontend proxies via nginx)
VITE_API_URL=/api/v1

# Internal API port inside the web container (do not change for Docker)
API_PORT=3000

# =============================================================================
# Logging & Rate Limiting
# =============================================================================
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Seeding (disable in production)
# =============================================================================
SEED_ON_STARTUP=false